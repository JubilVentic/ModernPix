# Public site URL (used for SEO, sitemap, Open Graph, JSON-LD)
# Set this to your custom domain in production, e.g. https://modernpix.ph
NEXT_PUBLIC_SITE_URL=https://modernpix.vercel.app

# Owner portal (required for /owner login)
OWNER_USERNAME=owner
OWNER_PASSWORD=change-me
# Optional separate signing secret (falls back to OWNER_PASSWORD)
OWNER_SESSION_SECRET=replace-with-a-long-random-string
